@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Duopharma</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="vh-100 overflow-hidden">
    <div class="container-fluid h-100 p-0">
        <div class="row g-0 h-100">
            <!-- Left Section: Carousel-->
            <div class="col-md-6 login-left">
                <div id="productCarousel" class="carousel slide d-flex flex-column justify-content-center h-100" data-bs-ride="carousel" data-bs-interval="3000">
                    <div class="carousel-inner text-center">
                        <!-- Slide 1 -->
                        <div class="carousel-item active">
                            <div class="carousel-content">
                                <div class="bg-white rounded-circle d-inline-block p-4 mb-4">
                                    <img src="~/images/basket_med.png" alt="Logo" class="img-fluid carousel-logo" style="width: 100px;" />
                                </div>
                                <h3 class="fw-bold">Browse Duopharma Products</h3>
                                <p>
                                    Gain access to our product images, detailed descriptions, dimensions,
                                    and dosage information.
                                </p>
                            </div>
                        </div>

                        <!-- Slide 2 -->
                        <div class="carousel-item">
                            <div class="carousel-content">
                                <div class="bg-white rounded-circle d-inline-block p-4 mb-4">
                                    <img src="~/images/basket_med1.png" alt="Quality" class="img-fluid carousel-logo" style="width: 100px;" />
                                </div>
                                <h3 class="fw-bold">Premium Quality</h3>
                                <p>
                                    Discover our range of high-quality pharmaceutical products
                                    that meet international standards.
                                </p>
                            </div>
                        </div>

                        <!-- Slide 3 -->
                        <div class="carousel-item">
                            <div class="carousel-content">
                                <div class="bg-white rounded-circle d-inline-block p-4 mb-4">
                                    <img src="~/images/basket_med2.png" alt="Research" class="img-fluid carousel-logo" style="width: 100px;" />
                                </div>
                                <h3 class="fw-bold">Research Backed</h3>
                                <p>
                                    All our products are developed through extensive research
                                    and clinical trials.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Carousel Indicators -->
                    <div class="carousel-indicators-container">
                        <button type="button" data-bs-target="#productCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                        <button type="button" data-bs-target="#productCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                        <button type="button" data-bs-target="#productCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
                    </div>

                </div>
            </div>

            <!-- Right Section: Login Form (optimized with Bootstrap) -->
            <div class="col-md-6 d-flex flex-column bg-white p-4 p-md-5">
                <div class="mb-4 pb-4">
                    <img src="~/images/dp_connext.png" alt="DpConnext Logo" style="height: 90px;" />
                </div>

                <div class="mx-auto w-100" style="max-width: 400px;">
                    <h2 class="text-dark fw-bold mb-4" style="font-size: 2rem;">Login</h2>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mb-4">@ViewBag.Error</div>
                    }

                    <form method="post" asp-action="Login" asp-controller="Auth">
                        <div class="mb-3">
                            <input type="email" class="form-control" placeholder="Email" required style="padding: 10px 12px; font-size: 14px;" />
                        </div>
                        <div class="mb-3">
                            <input type="password" class="form-control" placeholder="Password" required style="padding: 10px 12px; font-size: 14px;" />
                        </div>
                        <div class="mb-3 text-end">
                            <a href="#" style="font-size: 13px;">Forgot Password?</a>
                        </div>
                        <button type="submit" class="btn btn-danger w-100 rounded-pill py-2 mb-4">Login</button>

                        <div class="text-center mt-4">
                            <p class="mb-2">Don't have an account? <a href="#" class="text-danger fw-bold">Register Now</a></p>
                            <p class="text-muted small mb-0">By signing in, I agree to <a href="#" class="text-danger">Terms of Use</a> and <a href="#" class="text-danger">Privacy Policy</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>const carouselEl = document.querySelector('#productCarousel');
        const indicators = document.querySelectorAll('.carousel-indicators-container button');

        carouselEl.addEventListener('slid.bs.carousel', function () {
            const activeItem = carouselEl.querySelector('.carousel-item.active');
            const items = Array.from(carouselEl.querySelectorAll('.carousel-item'));
            const activeIndex = items.indexOf(activeItem);

            indicators.forEach(btn => btn.classList.remove('active'));
            if (indicators[activeIndex]) {
                indicators[activeIndex].classList.add('active');
            }
        });</script>
</body>
</html>